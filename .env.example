# Spring profile
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=angi
DB_USER=postgres
DB_PASS=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (must be at least 32 chars long for HS256)
JWT_SECRET=change-me-to-a-very-long-random-string-with-min-32-chars

# LLM
LLM_PROVIDER=claude
CLAUDE_API_KEY=
OPENAI_API_KEY=

# Weather
OPENWEATHER_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=

# Server
PORT=8080
